pipeline {
    agent any
    environment {
        DOCKER_IMAGE = "karansumathi01/leave-management-app:latest"
    }
    stages {
        stage('Clone') {
            steps { git 'https://github.com/your-username/leave-management-app.git' }
        }
        stage('Test') {
            steps { bat 'mvn clean test' } // Pipeline stops here if tests fail [cite: 328]
            post { always { junit 'target/surefire-reports/*.xml' } }
        }
        stage('Build & Push') {
            steps {
                bat 'mvn package -DskipTests'
                bat "docker build -t %DOCKER_IMAGE% ."
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'U', passwordVariable: 'P')]) {
                    bat "docker login -u %U% -p %P%"
                    bat "docker push %DOCKER_IMAGE%"
                }
            }
        }
        stage('Deploy') {
            steps { bat 'kubectl apply -f deployment.yaml' }
        }
    }
}
